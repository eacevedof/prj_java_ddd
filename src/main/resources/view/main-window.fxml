<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.javayog.modules.query.presentation.controllers.MainWindowController"
            prefWidth="1200" prefHeight="800">

    <!-- Top Menu Bar -->
    <top>
        <MenuBar>
            <Menu text="Connection">
                <MenuItem text="New Connection" onAction="#handleNewConnection"/>
                <MenuItem text="Edit Connection" onAction="#handleEditConnection"/>
                <MenuItem text="Delete Connection" onAction="#handleDeleteConnection"/>
                <SeparatorMenuItem/>
                <MenuItem text="Refresh" onAction="#handleRefreshConnections"/>
            </Menu>
            <Menu text="Query">
                <MenuItem text="Execute Query (F5)" onAction="#handleExecuteQuery"/>
                <MenuItem text="Export Results" onAction="#handleExportResults"/>
            </Menu>
            <Menu text="Help">
                <MenuItem text="About"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- Left Sidebar - Connections -->
    <left>
        <VBox spacing="10" prefWidth="250" style="-fx-padding: 10;">
            <Label text="Database Connections" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <ListView fx:id="connectionListView" VBox.vgrow="ALWAYS"/>
            <HBox spacing="5">
                <Button text="New" onAction="#handleNewConnection" prefWidth="75"/>
                <Button text="Edit" onAction="#handleEditConnection" prefWidth="75"/>
                <Button text="Delete" onAction="#handleDeleteConnection" prefWidth="75"/>
            </HBox>
        </VBox>
    </left>

    <!-- Center - Query Editor and Results -->
    <center>
        <SplitPane orientation="VERTICAL" dividerPositions="0.4">
            <!-- Query Editor -->
            <VBox spacing="10" style="-fx-padding: 10;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="SQL Query Editor" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Max Rows:"/>
                    <TextField fx:id="maxRowsTextField" prefWidth="80" promptText="1000"/>
                    <Button text="Execute (F5)" onAction="#handleExecuteQuery"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    <Button text="Export" onAction="#handleExportResults"/>
                </HBox>
                <TextArea fx:id="queryTextArea" VBox.vgrow="ALWAYS"
                          promptText="Enter your SQL query here..."
                          style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Results Table -->
            <VBox spacing="10" style="-fx-padding: 10;">
                <Label text="Query Results" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TableView fx:id="resultTableView" VBox.vgrow="ALWAYS"/>
            </VBox>
        </SplitPane>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10" style="-fx-padding: 5 10 5 10;">
                <Label text="Status:"/>
                <TextArea fx:id="statusTextArea" HBox.hgrow="ALWAYS" prefHeight="30"
                          editable="false" wrapText="true"
                          style="-fx-control-inner-background: transparent;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
